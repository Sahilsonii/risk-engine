# ------ Clerk Auth (API / Backend) ------
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_MERCHANT_ORG_ID=org_REPLACE_ME
CLERK_ADMIN_ORG_ID=org_REPLACE_ME

# ------ Clerk Auth (Frontend / Vite) ------
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ------ Database ------
DB_HOST=db
DB_PORT=5432
DB_USER=api_service
DB_PASS=api_service_pass
